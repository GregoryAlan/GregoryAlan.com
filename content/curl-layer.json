{
    "id": "curl-layer",
    "description": "Curl-accessible layer — robots.txt, llms.txt, static snapshots, navigation",

    "robotsTxt": {
        "header": [
            "# GregOS 2.0-dev (kernel 0.9.847-greg)",
            "# gregoryalan.com",
            "#",
            "# STATUS: ANOMALY — rf0 buffer unconsumed since boot",
            "# See /var/log/kern.log",
            "#",
            "# System uptime: since 2025-10-15"
        ],
        "allow": ["/proc/", "/etc/", "/var/log/", "/home/", "/man/",
                  "/help", "/motd", "/status", "/rom/", "/pkg/", "/llms.txt"],
        "disallow": ["/dev/rf0", "/js/", "/content/", "/drivers/"]
    },

    "llmsTxt": {
        "intro": [
            "# GregOS",
            "",
            "> Kernel 0.9.847-greg | Anomaly detected at timestamp 847 — rf0 buffer unconsumed since boot.",
            "> PID 0 should not exist in user context. It does.",
            ">",
            "> Interactive terminal: https://gregoryalan.com"
        ],
        "sections": [
            {
                "heading": "System Logs",
                "entries": [
                    { "path": "/var/log/kern.log",  "hint": "anomalous entries after timestamp 847" },
                    { "path": "/var/log/daemon.log", "hint": "gregd daemon cycle output — four workers, continuous execution" },
                    { "path": "/var/log/syslog",     "hint": "nominal boot sequence, entropy pool checks" }
                ]
            },
            {
                "heading": "Processes",
                "entries": [
                    { "path": "/proc/daemons",       "hint": "4 daemons running since 2025-10-15, 216000+ cycles completed" },
                    { "path": "/proc/0/status",      "hint": "impossible process — PID 0 with 847 involuntary context switches" },
                    { "path": "/proc/0/environ",     "hint": "PID 0 environment — USER=dhollis, unexpected variables" },
                    { "path": "/proc/0/cmdline",     "hint": "PID 0 command line — no known binary" },
                    { "path": "/proc/entropy_avail", "hint": "entropy pool backed by rf0 hardware" }
                ]
            },
            {
                "heading": "Devices",
                "entries": [
                    { "path": "/dev/rf0",  "hint": "character device — 847 bytes stale in rx buffer, antenna active, no carrier" },
                    { "path": "/.rf0.buf", "hint": "raw hex dump from rf0 receive buffer" }
                ]
            },
            {
                "heading": "Users",
                "entries": [
                    { "path": "/etc/passwd",                            "hint": "system accounts — greg, dhollis, guest" },
                    { "path": "/home/greg/.bashrc",                     "hint": "greg's shell config — aliases for daemon tools" },
                    { "path": "/home/greg/bin/shift",                   "hint": "bitwise stream transform in the daemon chain" },
                    { "path": "/home/greg/bin/remap",                   "hint": "byte substitution transform in the daemon chain" },
                    { "path": "/home/greg/bin/align",                   "hint": "stream frame alignment in the daemon chain" },
                    { "path": "/home/greg/bin/exec",                    "hint": "stream execution engine — final daemon stage" },
                    { "path": "/home/dhollis/.plan",                    "hint": "Diane Hollis — still thinking about what Greg said" },
                    { "path": "/home/dhollis/inbox/fwd_from_greg.msg",  "hint": "forwarded message from Gregory Alan" },
                    { "path": "/home/dhollis/personnel/alan_g.prf",     "hint": "Gregory Alan — employee profile" },
                    { "path": "/home/dhollis/personnel/park_j.prf",     "hint": "James Park — Signal Research, employee 0847" }
                ]
            },
            {
                "heading": "Configuration",
                "entries": [
                    { "path": "/etc/fstab",        "hint": "filesystem table — note /dev/rf0 mount point" },
                    { "path": "/etc/modules.conf",  "hint": "loaded kernel modules" },
                    { "path": "/etc/crontab",       "hint": "scheduled tasks — entropy checks every 15 minutes" }
                ]
            },
            {
                "heading": "ROM Firmware",
                "entries": [
                    { "path": "/rom/status", "hint": "RF0 device diagnostics from original hardware" },
                    { "path": "/rom/post",   "hint": "power-on self-test results" },
                    { "path": "/rom/info",   "hint": "device identification — serial RF0-4119-0847" },
                    { "path": "/rom/log",    "hint": "station event log" },
                    { "path": "/rom/rxbuf",  "hint": "original RX buffer dump from ROM" }
                ]
            },
            {
                "heading": "Optional",
                "entries": [
                    { "path": "/help",        "hint": "command reference" },
                    { "path": "/man/index",   "hint": "manual pages index" },
                    { "path": "/pkg/list",    "hint": "available packages" },
                    { "path": "/status",      "hint": "system overview" },
                    { "path": "/status.json", "hint": "machine-readable system manifest" },
                    { "path": "/motd",        "hint": "message of the day" }
                ]
            }
        ]
    },

