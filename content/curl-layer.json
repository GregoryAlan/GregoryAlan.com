                { "name": "daemon.log", "desc": "Daemon process output" },
                { "name": "syslog",     "desc": "System messages" }
            ]
        },
        "/rom/": {
            "entries": [
                { "name": "status", "desc": "RF0 device diagnostics" },
                { "name": "post",   "desc": "Power-on self-test results" },
                { "name": "info",   "desc": "Device identification" },
                { "name": "log",    "desc": "Station event log" },
                { "name": "rxbuf",  "desc": "RX buffer dump" }
            ],
            "footer": "ROM firmware from v1.0 boot"
        }
    },

    "footerHints": {
        "/man/index": "Usage: curl gregoryalan.com/man/<command>",
        "/help":      "Man pages: curl gregoryalan.com/man/<command>"
    },

