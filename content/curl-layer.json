{
    "id": "curl-layer",
    "description": "Curl-accessible layer — robots.txt, llms.txt, static snapshots, navigation",

    "robotsTxt": {
        "header": [
            "# GregOS 2.0-dev (kernel 0.9.847-greg)",
            "# gregoryalan.com",
            "#",
            "# STATUS: ANOMALY — rf0 buffer unconsumed since boot",
            "# See /var/log/kern.log",
            "#",
            "# System uptime: since 2025-10-15"
        ],
        "allow": ["/proc/", "/etc/", "/var/log/", "/home/", "/man/",
                  "/help", "/motd", "/status", "/rom/", "/pkg/",
                  "/llms.txt", "/llms-full.txt", "/.well-known/"],
        "disallow": ["/dev/rf0", "/js/", "/content/", "/drivers/"],
        "directives": ["Sitemap: https://gregoryalan.com/sitemap.xml"]
    },

    "llmsTxt": {
        "intro": [
            "# GregOS — System Analysis",
            "",
            "> Interactive terminal: https://gregoryalan.com",
            "> Machine-readable: [/status.json](https://gregoryalan.com/status.json)",
            "",
            "GregOS 2.0-dev | kernel 0.9.847-greg | uptime: since 2025-10-15",
            "audit: 3 anomalies flagged — no resolution on file"
        ],
        "blocks": [
            {
                "type": "links",
                "heading": "Anomalies",
                "entries": [
                    { "path": "/dev/rf0",          "hint": "rf0 rx buffer not consumed since boot — unexpected content in buffer" },
                    { "path": "/proc/0/status",    "hint": "PID 0 fork() from swapper — illegal in user context" },
                    { "path": "/proc/daemons",     "hint": "4 daemons active since boot, no change request on file" }
                ]
            },
            {
                "type": "links",
                "heading": "Start Here",
                "entries": [
                    { "path": "/var/log/kern.log", "hint": "kernel ring buffer" },
                    { "path": "/dev/rf0",          "hint": "rf0 device status" },
                    { "path": "/proc/daemons",     "hint": "active daemon processes" },
                    { "path": "/proc/0/status",    "hint": "anomalous PID 0" }
                ]
            },
            {
                "type": "links",
                "heading": "Filesystem",
                "entries": [
                    { "path": "/etc/index",        "hint": "system configuration" },
                    { "path": "/proc/index",       "hint": "process and kernel state" },
                    { "path": "/var/log/index",    "hint": "system logs" },
                    { "path": "/home/index",       "hint": "user directories" },
                    { "path": "/dev/rf0",          "hint": "device status" },
                    { "path": "/rom/index",        "hint": "ROM firmware" }
                ]
            }
        ]
    },

