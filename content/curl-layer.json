    },

    "seeAlso": {
        "/var/log/kern.log": ["/proc/daemons", "/dev/rf0"],
        "/status":           ["/var/log/kern.log", "/proc/daemons", "/etc/passwd"],
        "/home/index":       ["/etc/passwd"],
        "/var/log/index":    ["/proc/daemons"]
    },

    "directoryIndexes": {
        "/etc/": {
            "entries": [
                { "name": "hostname",       "desc": "System hostname" },
                { "name": "passwd",         "desc": "User accounts" },
                { "name": "fstab",          "desc": "Filesystem table" },
                { "name": "motd",           "desc": "Message of the day" },
                { "name": "crontab",        "desc": "Scheduled tasks" },
                { "name": "modules.conf",   "desc": "Loaded kernel modules" },
                { "name": "gregos-release", "desc": "OS release info" }
            ],
            "usageHint": "Usage: curl gregoryalan.com/etc/<file>"
        },
        "/proc/": {
            "entries": [
                { "name": "version",       "desc": "Kernel version string" },
                { "name": "cpuinfo",       "desc": "CPU information" },
                { "name": "meminfo",       "desc": "Memory information" },
                { "name": "daemons",       "desc": "Running daemon processes" },
                { "name": "entropy_avail", "desc": "Entropy pool status" },
                { "name": "0/",            "desc": "PID 0 (anomalous process)" }
            ],
            "usageHint": "Usage: curl gregoryalan.com/proc/<file>"
        },
        "/home/": {
            "entries": [
                { "name": "greg/",    "desc": "Gregory Alan (system owner)" },
                { "name": "dhollis/", "desc": "Diane Hollis (HR director)" },
                { "name": "guest/",   "desc": "Visitor account" }
            ]
        },
        "/var/log/": {
